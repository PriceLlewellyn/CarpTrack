{
  "name": "monorepo",
  "version": "1.0.0",
  "description": "Vector",
  "private": true,
  "type": "module",
  "scripts": {
    "serve:frontend": "pnpm --filter frontend-ui dev",
    "serve:frontend:localbe": "pnpm --filter frontend-ui dev:localbe",
    "serve:api": "pnpm --filter backend-api dev",
    "storybook": "pnpm --filter frontend-ui storybook",

    "seed": "pnpm --filter backend-api seed",
    "db:generate": "pnpm --filter backend-api prisma:generate",
    "db:migrate": "pnpm --filter backend-api prisma:migrate",
    "db:studio": "pnpm --filter backend-api prisma:studio",

    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "e2e:smoke": "pnpm --filter frontend-ui e2e:smoke",
    "generate:ato-files": "ts-node ./scripts/testing/ato-file/generate-ato-file.ts yesterday today tomorrow",

    "prepare": "husky",
    "pre-commit": "lint-staged && pnpm --filter backend-api build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",

    "migration:generate": "pnpm db:migrate",
    "migration:run": "pnpm db:migrate"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "prettier": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",

    "@chromatic-com/storybook": "catalog:",
    "@faker-js/faker": "catalog:",
    "@playwright/test": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:",
    "reflect-metadata": "catalog:",
    "zod": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.20.0"
}