// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  email     String     @unique
  age       Int        
  fisherman Boolean    @default(false)
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  catches   Catch[]
  gear      Gear[]
  baits     Bait[]
  waypoints Waypoint[]
  sessions  Session[]
}

model Gear {
  id        Int      @id @default(autoincrement())
  brand     String
  model     String
  type      String   
  subType   String?
  size      String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catches   Catch[]
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Bait {
  id        Int      @id @default(autoincrement())
  name      String
  flavor    String?
  type      String  
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catches   Catch[]
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Session {
  id          Int          @id @default(autoincrement())
  title       String?
  style       String       @default("General Coarse") 
  startTime   DateTime     @default(now())
  endTime     DateTime?
  pegNumber   String?
  totalWeight Float?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  catches     Catch[]
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
}

model Catch {
  id          Int      @id @default(autoincrement())
  species     String
  weight      Float?
  length      Float?
  imageUrl    String?
  fishName    String?
  isPB        Boolean  @default(false)
  lat         Float
  lng         Float
  waterTemp   Float?
  pressure    Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessionId   Int?
  session     Session? @relation(fields: [sessionId], references: [id])
  gearId      Int?
  gear        Gear?    @relation(fields: [gearId], references: [id])
  baitId      Int?
  bait        Bait?    @relation(fields: [baitId], references: [id])
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Waypoint {
  id         Int       @id @default(autoincrement())
  label      String
  type       String    
  lat        Float
  lng        Float
  depth      Float?
  bottomType String?
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  userId     Int
  user       User      @relation(fields: [userId], references: [id])
}