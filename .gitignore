# --- Monorepo / Package Manager ---
node_modules
**/node_modules
pnpm-lock.yaml
# Keep the root lockfile, but ignore accidental npm/yarn ones
package-lock.json
yarn.lock

# --- Compiled Output ---
dist
**/dist
build
**/build
/generated
**/generated

# --- Database & Docker ---
# Crucial: Ignore the actual DB binary data from your Docker volume
postgres_data/
**/postgres_data/
*.db
*.db-journal

# --- Prisma ---
# Ignore generated client if it's not in node_modules
/generated/prisma
**/generated/prisma

# --- Logs ---
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --- OS & IDEs ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
.project
.classpath
.settings/

# --- Environment Variables ---
# Never commit these!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local

# --- Tests & Coverage ---
coverage/
**/coverage/
.nyc_output

# --- Temp / Runtime ---
.temp
.tmp
pids
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json